generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum QuestionStatus {
  PENDING
  REVIEWING
  APPROVED
  REJECTED
  NEEDS_REVISION
}

enum ExamStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum ActivationCodeStatus {
  UNUSED
  USED
  EXPIRED
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  username      String?   @unique
  password      String
  name          String    @default("")
  avatar        String?
  role          UserRole  @default(USER)
  isActivated   Boolean   @default(false)
  emailVerified Boolean   @default(false)
  activatedAt   DateTime?
  banned        Boolean   @default(false)
  bannedReason  String?
  bannedAt      DateTime?
  deletedAt     DateTime?
  lastLoginAt   DateTime?
  lastLoginIp   String?
  deviceId      String?
  todayUsedSeconds Int   @default(0)
  lastUsedDate  DateTime?
  activationCode ActivationCode?
  sessions      UserSession[]
  uploads       QuestionBank[]        @relation("BankUploader")
  reviewedBanks QuestionBank[]        @relation("BankReviewer")
  records       UserQuestionRecord[]
  favorites     Favorite[]
  notes         Note[]
  auditLogs     AuditLog[]
  exams         Exam[]
  submittedReports Report[]             @relation("ReportReporter")
  handledReports   Report[]             @relation("ReportHandler")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([email])
  @@index([username])
  @@index([role])
  @@index([banned])
  @@index([isActivated])
  @@index([emailVerified])
  @@index([createdAt])
}

model UserSession {
  id          String    @id @default(uuid())
  userId      String
  token       String    @unique
  deviceId    String
  ip          String?
  userAgent   String?
  isActive    Boolean   @default(true)
  lastPingAt  DateTime  @default(now())
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([lastPingAt])
  @@index([isActive])
}

model ActivationCode {
  id          String               @id @default(uuid())
  code        String               @unique
  prefix      String               @default("")
  batchId     String
  duration    Int                  @default(0)
  isUsed      Boolean              @default(false)
  usedById    String?              @unique
  usedAt      DateTime?
  expiresAt   DateTime?
  status      ActivationCodeStatus @default(UNUSED)
  usedBy      User?                @relation(fields: [usedById], references: [id])
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([code])
  @@index([batchId])
  @@index([status])
  @@index([isUsed])
  @@index([expiresAt])
}

model QuestionBank {
  id               String          @id @default(uuid())
  title            String
  description      String?
  source           String          @default("")
  category         String          @default("")
  tags             String[]        @default([])
  difficulty       Int             @default(1)
  status           QuestionStatus  @default(PENDING)
  isPublic         Boolean         @default(false)
  uploaderId       String
  reviewComment    String?
  reviewedById     String?
  reviewedAt       DateTime?
  reviewTemplateId String?
  uploader         User            @relation("BankUploader", fields: [uploaderId], references: [id])
  reviewer         User?           @relation("BankReviewer", fields: [reviewedById], references: [id])
  reviewTemplate   ReviewTemplate? @relation(fields: [reviewTemplateId], references: [id])
  questions        Question[]
  reports          Report[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([status])
  @@index([category])
  @@index([difficulty])
  @@index([isPublic])
  @@index([uploaderId])
  @@index([reviewedById])
  @@index([createdAt])
  @@index([status, createdAt])
}

model Question {
  id            String              @id @default(uuid())
  bankId        String
  type          String              @default("single")
  content       String
  options       Json                @default("[]")
  answer        String
  analysis      String?
  image         String?
  sortOrder     Int                 @default(0)
  bank          QuestionBank        @relation(fields: [bankId], references: [id], onDelete: Cascade)
  records       UserQuestionRecord[]
  favorites     Favorite[]
  notes         Note[]
  examQuestions ExamQuestion[]
  reports       Report[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([bankId])
  @@index([type])
  @@index([createdAt])
}

model UserQuestionRecord {
  id          String    @id @default(uuid())
  userId      String
  questionId  String
  userAnswer  String
  isCorrect   Boolean
  duration    Int       @default(0)
  sessionId   String?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  question    Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([questionId])
  @@index([isCorrect])
  @@index([createdAt])
  @@index([userId, isCorrect])
  @@index([userId, createdAt])
}

model Favorite {
  id          String    @id @default(uuid())
  userId      String
  questionId  String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  question    Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([userId, questionId])
  @@index([userId])
}

model Note {
  id            String    @id @default(uuid())
  userId        String
  questionId    String
  content       String
  importance    Int       @default(0)
  isAiGenerated Boolean   @default(false)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  question      Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([userId, questionId])
  @@index([userId])
  @@index([userId, importance])
  @@index([isAiGenerated])
}

model SystemConfig {
  id          String    @id @default(uuid())
  key         String    @unique
  value       String
  description String    @default("")
  updatedAt   DateTime  @updatedAt

  @@index([key])
}

model AuditLog {
  id          String    @id @default(uuid())
  userId      String?
  action      String
  details     String?
  ip          String?
  userAgent   String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model RateLimit {
  id          String    @id @default(uuid())
  key         String    @unique
  count       Int       @default(0)
  resetAt     DateTime
  createdAt   DateTime  @default(now())

  @@index([key])
  @@index([resetAt])
}

model Exam {
  id              String       @id @default(uuid())
  title           String
  description     String?
  userId          String
  durationMinutes Int          @default(60)
  difficulty      Int          @default(3)
  totalQuestions  Int          @default(0)
  correctCount    Int          @default(0)
  score           Float        @default(0)
  status          ExamStatus   @default(DRAFT)
  startedAt       DateTime?
  completedAt     DateTime?
  settings        Json         @default("{}")
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions       ExamQuestion[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@index([createdAt])
}

model ExamQuestion {
  id          String   @id @default(uuid())
  examId      String
  questionId  String
  userAnswer  String?
  isCorrect   Boolean?
  sortOrder   Int      @default(0)
  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([examId])
  @@index([questionId])
  @@unique([examId, questionId])
}

model ReviewTemplate {
  id          String          @id @default(uuid())
  name        String
  content     String
  category    String          @default("")
  isDefault   Boolean         @default(false)
  createdBy   String?
  questionBanks QuestionBank[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([category])
  @@index([isDefault])
}

model ReviewerDailyStats {
  id           String   @id @default(uuid())
  userId       String
  date         DateTime
  reviewedCount Int    @default(0)
  approvedCount Int    @default(0)
  rejectedCount Int    @default(0)
  needsRevisionCount Int @default(0)
  avgReviewTime  Int   @default(0)
  createdAt    DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model LoginAttempt {
  id        String    @id @default(uuid())
  userId    String?
  email     String
  ip        String
  success   Boolean
  reason    String?
  userAgent String?
  createdAt DateTime  @default(now())

  @@index([ip])
  @@index([userId])
  @@index([email])
  @@index([createdAt])
  @@index([ip, success, createdAt])
  @@index([success, createdAt])
}

model IpBlockRule {
  id        String    @id @default(uuid())
  ip        String    @unique
  reason    String?
  blockedAt DateTime  @default(now())
  blockedBy String?
  expiresAt DateTime?

  @@index([ip])
  @@index([expiresAt])
}

model AiCache {
  id         String   @id @default(uuid())
  promptHash String   @unique
  prompt     String
  response   String
  model      String   @default("")
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  @@index([promptHash])
  @@index([expiresAt])
}

model Report {
  id              String          @id @default(uuid())
  reporterId      String
  questionBankId  String
  questionId      String?
  reason          String
  status          String          @default("PENDING")
  handledById     String?
  handledAt       DateTime?
  handleNote      String?
  reporter        User            @relation("ReportReporter", fields: [reporterId], references: [id])
  questionBank    QuestionBank    @relation(fields: [questionBankId], references: [id], onDelete: Cascade)
  question        Question?       @relation(fields: [questionId], references: [id], onDelete: SetNull)
  handler         User?           @relation("ReportHandler", fields: [handledById], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([reporterId])
  @@index([questionBankId])
  @@index([status])
  @@index([createdAt])
}
