# NovaMind 环境变量配置
# 复制此文件为 .env 并填写实际值

# 数据库 (PostgreSQL)
DATABASE_URL="postgresql://novamind:novamind_password@postgres:5432/novamind?schema=public"

# Redis
REDIS_URL="redis://redis:6379"

# Auth 密钥 (运行 openssl rand -base64 32 生成)
AUTH_SECRET="change-me-to-a-random-string-at-least-32-chars"
JWT_SECRET="change-me-to-a-random-jwt-secret-key"

# 应用配置
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="production"

# SMTP 邮件配置 (可在管理员后台修改)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="noreply@example.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="NovaMind <noreply@example.com>"

# AI 配置 (可在管理员后台修改)
AI_PROVIDER="openai"
AI_API_KEY=""
AI_MODEL="gpt-4o-mini"
AI_BASE_URL="https://api.openai.com/v1"

# 体验版配置 (分钟数，可在管理员后台修改)
TRIAL_DAILY_MINUTES="30"
TRIAL_ENABLED="true"

# 上传文件大小限制 (MB)
MAX_UPLOAD_SIZE_MB="10"

# WebSocket
WS_PORT="3001"
