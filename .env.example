# NovaMind 环境变量配置
# Docker 部署无需手动配置此文件，首次启动会自动生成密钥并初始化数据库

# 数据库 (PostgreSQL) — Docker 部署使用默认值即可
DATABASE_URL="postgresql://novamind:novamind_password@postgres:5432/novamind?schema=public&connection_limit=20"

# Redis — Docker 部署使用默认值即可
REDIS_URL="redis://redis:6379"

# JWT 签名密钥 — Docker 部署自动生成，无需手动设置
JWT_SECRET=""

# 应用配置
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="production"

# SMTP 邮件 (可选，可在管理员后台修改)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# AI 配置 (可选，可在管理员后台修改)
AI_PROVIDER="openai"
AI_API_KEY=""
AI_MODEL="gpt-4o-mini"
AI_BASE_URL="https://api.openai.com/v1"
